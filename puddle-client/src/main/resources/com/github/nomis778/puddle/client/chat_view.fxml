<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<GridPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.github.nomis778.puddle.client.ChatViewController">
    <columnConstraints>
          <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" percentWidth="30.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="105.0" />
      <ColumnConstraints hgrow="ALWAYS" maxWidth="751.0" minWidth="10.0" percentWidth="5.0" prefWidth="735.0" />
    </columnConstraints>
    <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="ALWAYS" />
      <RowConstraints minHeight="10.0" percentHeight="80.0" prefHeight="30.0" vgrow="ALWAYS" />
      <RowConstraints minHeight="10.0" percentHeight="5.0" prefHeight="30.0" vgrow="ALWAYS" />
    </rowConstraints>
    <children>
          <Button mnemonicParsing="false" onAction="#refreshMatchBox" text="Refresh" />
      <VBox fx:id="matchBox" prefHeight="200.0" prefWidth="100.0" GridPane.rowIndex="1" GridPane.rowSpan="2" />
      <TextField GridPane.columnIndex="1" GridPane.rowIndex="2">
         <GridPane.margin>
            <Insets left="10.0" />
         </GridPane.margin>
      </TextField>
      <Button mnemonicParsing="false" text="Send" GridPane.columnIndex="2" GridPane.rowIndex="2" />
    </children>
</GridPane>
